# Copy this file to .env and fill in the values.
# Never commit .env to Git.

# MongoDB Connection String
# For local dev: mongodb://localhost:27017/medai
# For production: Get this from MongoDB Atlas
MONGO_URI=mongodb://localhost:27017/medai

# JWT Secret - Use a long, random string for production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port for the Node.js server
PORT=3001

# URL of the Python Flask inference server
# For local dev: http://localhost:5001
# For production: Your Hugging Face Spaces URL
PYTHON_API_URL=http://localhost:5001

# Allowed frontend origin (for CORS)
# For local dev: http://localhost:5173
# For production: Your Vercel URL
FRONTEND_URL=http://localhost:5173
